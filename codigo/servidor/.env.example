# ──────────────────────────────────────────────────────────────
# SiGIC · Plantilla de configuración del servidor
# Copiá este archivo como `.env` y completá los valores reales.
# El archivo `.env` está ignorado por git: NUNCA subas secretos.
# ──────────────────────────────────────────────────────────────

# Conexión a PostgreSQL (Neon). Si se omite, se usa SQLite local.
DATABASE_URL="postgresql://usuario:contraseña@host/basededatos?sslmode=require"

# Secreto para firmar los tokens de sesión (mínimo 32 caracteres).
# Generá uno aleatorio, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# Orígenes permitidos para CORS en producción (separados por coma).
# Vacío = cualquier origen (solo aceptable en desarrollo).
# CORS_ORIGINS="https://sigic.ejemplo.edu.ar,http://localhost:5173"

# URL pública del portal web (se usa para armar los links de invitación
# en los correos). Si se omite, se usa el Origin de la petición.
# FRONTEND_URL="https://sigic.ejemplo.edu.ar"

# Solo como escape temporal si la red rompe la cadena de certificados TLS
# de la base de datos. Desactiva la verificación: usar bajo riesgo propio.
# DB_SSL_INSECURE=1

# Configuración de correo SMTP (para Gmail usá una "contraseña de aplicación")
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE="false"
EMAIL_USER="correo@ejemplo.com"
EMAIL_PASS=""
EMAIL_FROM_NAME="SiGIC - Instituto Beltrán"
