<Window x:Class="SiGIC_ControlCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SiGIC_ControlCenter"
        mc:Ignorable="d"
        Title="SiGIC Control Center" Height="720" Width="1120" MinHeight="620" MinWidth="940"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <!-- Estilos base Fluent para botones -->
        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonSecBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonSecFgBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" 
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="true"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonSecHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="{DynamicResource TextSuaveBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonSecBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="true"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AcentoHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AcentoPresionadoBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#88FFFFFF"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource TextSuaveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilos para Labels y Textbox -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable Text"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource EntradaBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource EntradaFgBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="4" Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable Text"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel de navegación izquierdo -->
        <Grid x:Name="panelNavegacion" Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabecera Logo y Título -->
            <StackPanel Grid.Row="0" Margin="22,24,22,22">
                <Label Content="SiGIC" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Padding="0"/>
                <Label Content="Centro de Control Operativo" FontSize="11" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
                <Label x:Name="lblVersion" Content="v5.1.0" FontSize="10" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
            </StackPanel>

            <!-- Botones Operativos -->
            <StackPanel Grid.Row="1" Margin="18,0">
                <Button x:Name="btnInfra" Content="Iniciar infraestructura" Style="{StaticResource FluentPrimaryButtonStyle}" Margin="0,0,0,8" Click="btnInfra_Click"/>
                <Button x:Name="btnAbrir" Content="Abrir frontend" Style="{StaticResource FluentButtonStyle}" Margin="0,0,0,8" Click="btnAbrir_Click"/>
                <Button x:Name="btnGuardar" Content="Guardar configuración" Style="{StaticResource FluentButtonStyle}" Margin="0,0,0,8" Click="btnGuardar_Click"/>
                <Button x:Name="btnSetup" Content="Forzar setup inicial" Style="{StaticResource FluentButtonStyle}" Margin="0,0,0,8" Click="btnSetup_Click"/>
            </StackPanel>

            <!-- Selectores de Entorno y Tema -->
            <StackPanel Grid.Row="2" Margin="18,0,18,24">
                <Label Content="ENTORNO" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSuaveBrush}" Margin="4,0,0,2"/>
                <ComboBox x:Name="comboEntorno" Margin="0,0,0,14" SelectionChanged="comboEntorno_SelectionChanged">
                    <ComboBoxItem Content="local"/>
                    <ComboBoxItem Content="vps"/>
                    <ComboBoxItem Content="aws"/>
                    <ComboBoxItem Content="firebase"/>
                </ComboBox>

                <Label Content="TEMA" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSuaveBrush}" Margin="4,0,0,2"/>
                <ComboBox x:Name="comboTema" SelectionChanged="comboTema_SelectionChanged">
                    <ComboBoxItem Content="sistema"/>
                    <ComboBoxItem Content="claro"/>
                    <ComboBoxItem Content="oscuro"/>
                </ComboBox>
            </StackPanel>

            <!-- Pie de Página -->
            <Label Grid.Row="3" Content="Instituto Tecnológico Beltrán" FontSize="11" Foreground="{DynamicResource TextSuaveBrush}" Margin="22,0,22,16"/>
        </Grid>

        <!-- Contenido principal derecho -->
        <Grid Grid.Column="1" Margin="22,18,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título de sección -->
            <Label Grid.Row="0" Content="Centro de control" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12" Padding="0"/>

            <!-- Tarjetas de estado -->
            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tarjeta: Estado Global -->
                <Border Grid.Column="0" Margin="0,0,4,0" CornerRadius="8" BorderThickness="1" 
                        Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        Padding="14,10">
                    <StackPanel>
                        <Label Content="Estado global" FontSize="11" Foreground="{DynamicResource TextSuaveBrush}" Padding="0"/>
                        <Label x:Name="lblEstadoGeneral" Content="Standby" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
                        <Label x:Name="lblDetalleGeneral" Content="Servicios inactivos" FontSize="9.5" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta: Backend -->
                <Border Grid.Column="1" Margin="4,0" CornerRadius="8" BorderThickness="1" 
                        Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        Padding="14,10">
                    <StackPanel>
                        <Label Content="Servicio Backend" FontSize="11" Foreground="{DynamicResource TextSuaveBrush}" Padding="0"/>
                        <Label x:Name="lblEstadoBackend" Content="—" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
                        <Label x:Name="lblDetalleBackend" Content="Puerto: 3001" FontSize="9.5" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta: Frontend -->
                <Border Grid.Column="2" Margin="4,0" CornerRadius="8" BorderThickness="1" 
                        Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        Padding="14,10">
                    <StackPanel>
                        <Label Content="Servicio Frontend" FontSize="11" Foreground="{DynamicResource TextSuaveBrush}" Padding="0"/>
                        <Label x:Name="lblEstadoFrontend" Content="—" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
                        <Label x:Name="lblDetalleFrontend" Content="Puerto: 5173" FontSize="9.5" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta: Base de Datos -->
                <Border Grid.Column="3" Margin="4,0,0,0" CornerRadius="8" BorderThickness="1" 
                        Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        Padding="14,10">
                    <StackPanel>
                        <Label x:Name="lblTituloDB" Content="Base de Datos" FontSize="11" Foreground="{DynamicResource TextSuaveBrush}" Padding="0"/>
                        <Label x:Name="lblEstadoDB" Content="—" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
                        <Label x:Name="lblDetalleDB" Content="Sin consultas" FontSize="9.5" Foreground="{DynamicResource TextSuaveBrush}" Padding="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tarjeta de Direcciones del Entorno -->
            <Border Grid.Row="2" Margin="0,0,0,14" CornerRadius="8" BorderThickness="1" 
                    Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Direcciones del entorno" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8" Padding="0"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="URL del backend" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource TextSuaveBrush}" Padding="0"/>
                    <TextBox x:Name="txtBackendUrl" Grid.Row="1" Grid.Column="1" Margin="0,4" FontSize="13"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="URL del frontend" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource TextSuaveBrush}" Padding="0"/>
                    <TextBox x:Name="txtFrontendUrl" Grid.Row="2" Grid.Column="1" Margin="0,4" FontSize="13"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="URL de la base de datos" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource TextSuaveBrush}" Padding="0"/>
                    <TextBox x:Name="txtDatabaseUrl" Grid.Row="3" Grid.Column="1" Margin="0,4" FontSize="13"/>
                </Grid>
            </Border>

            <!-- Consola de registro de actividad -->
            <Border Grid.Row="3" CornerRadius="8" BorderThickness="1" 
                    Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Registro de actividad" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Padding="0" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Probar conexiones" Style="{StaticResource FluentButtonStyle}" Padding="10,5" Click="btnProbar_Click"/>
                    </Grid>

                    <RichTextBox x:Name="rtbConsole" Grid.Row="1" Margin="1,0,1,1" Background="{DynamicResource ConsolaBgBrush}" 
                                 Foreground="{DynamicResource ConsolaFgBrush}" BorderThickness="0"
                                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas" FontSize="13">
                        <FlowDocument>
                            <Paragraph Margin="0"/>
                        </FlowDocument>
                    </RichTextBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
